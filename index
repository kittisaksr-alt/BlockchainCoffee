<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>☕ CoffeeChain - Roasting Profile DApp</title>
    <script src="https://cdn.jsdelivr.net/npm/ethers@5.7.2/dist/ethers.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* ============================================
           GLOBAL STYLES & VARIABLES
        ============================================ */
        :root {
            --coffee-dark:    #2C1810;
            --coffee-medium:  #6F4E37;
            --coffee-light:   #C4A882;
            --coffee-cream:   #F5F0E8;
            --coffee-gold:    #D4AF37;
            --coffee-green:   #4CAF50;
            --coffee-red:     #E53935;
            --coffee-blue:    #1565C0;
            --shadow:         0 8px 32px rgba(44, 24, 16, 0.3);
            --border-radius:  16px;
            --transition:     all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #2C1810 0%, #6F4E37 50%, #2C1810 100%);
            min-height: 100vh;
            color: var(--coffee-cream);
            background-attachment: fixed;
        }

        /* ============================================
           ANIMATED BACKGROUND
        ============================================ */
        body::before {
            content: '';
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' 
                viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E
                %3Cg fill='none' fill-rule='evenodd'%3E
                %3Cg fill='%23ffffff' fill-opacity='0.03'%3E
                %3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E
                %3C/g%3E%3C/g%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
        }

        /* ============================================
           HEADER / NAVBAR
        ============================================ */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(44, 24, 16, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: 2px solid var(--coffee-gold);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow);
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .navbar-logo {
            font-size: 2.5rem;
            animation: steam 2s ease-in-out infinite;
        }

        @keyframes steam {
            0%, 100% { transform: translateY(0px) rotate(-5deg); }
            50%       { transform: translateY(-5px) rotate(5deg); }
        }

        .navbar-title {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--coffee-gold), var(--coffee-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .navbar-subtitle {
            font-size: 0.75rem;
            color: var(--coffee-light);
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .navbar-actions {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .network-badge {
            background: rgba(212, 175, 55, 0.2);
            border: 1px solid var(--coffee-gold);
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 0.8rem;
            color: var(--coffee-gold);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .network-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--coffee-green);
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: 0.5; transform: scale(1.3); }
        }

        /* ============================================
           BUTTONS
        ============================================ */
        .btn {
            padding: 10px 24px;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 700;
            font-size: 0.9rem;
            transition: var(--transition);
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            overflow: hidden;
        }

        .btn::after {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            width: 0; height: 0;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn:active::after {
            width: 300px;
            height: 300px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--coffee-gold), #B8860B);
            color: var(--coffee-dark);
            box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(212, 175, 55, 0.6);
        }

        .btn-secondary {
            background: linear-gradient(135deg, var(--coffee-medium), var(--coffee-dark));
            color: var(--coffee-cream);
            border: 1px solid var(--coffee-light);
        }

        .btn-secondary:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, var(--coffee-light), var(--coffee-medium));
            color: var(--coffee-dark);
        }

        .btn-success {
            background: linear-gradient(135deg, #4CAF50, #2E7D32);
            color: white;
            box-shadow: 0 4px 15px rgba(76, 175, 80, 0.4);
        }

        .btn-danger {
            background: linear-gradient(135deg, #E53935, #B71C1C);
            color: white;
        }

        .btn-sm {
            padding: 6px 16px;
            font-size: 0.8rem;
        }

        /* ============================================
           MAIN CONTAINER
        ============================================ */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 20px;
            position: relative;
            z-index: 1;
        }

        /* ============================================
           WALLET CONNECTION PANEL
        ============================================ */
        .wallet-panel {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: var(--border-radius);
            padding: 25px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .wallet-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .wallet-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--coffee-gold), var(--coffee-medium));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
        }

        .wallet-details h3 {
            font-size: 1rem;
            color: var(--coffee-gold);
            margin-bottom: 4px;
        }

        .wallet-address {
            font-size: 0.85rem;
            color: var(--coffee-light);
            font-family: 'Courier New', monospace;
        }

        .wallet-stats {
            display: flex;
            gap: 25px;
        }

        .wallet-stat {
            text-align: center;
        }

        .wallet-stat-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--coffee-gold);
        }

        .wallet-stat-label {
            font-size: 0.75rem;
            color: var(--coffee-light);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ============================================
           STATS DASHBOARD
        ============================================ */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: var(--border-radius);
            padding: 20px;
            text-align: center;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 3px;
            background: linear-gradient(90deg, var(--coffee-gold), var(--coffee-light));
        }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: var(--coffee-gold);
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.2);
        }

        .stat-icon {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            color: var(--coffee-gold);
        }

        .stat-label {
            font-size: 0.8rem;
            color: var(--coffee-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 5px;
        }

        .stat-change {
            font-size: 0.75rem;
            margin-top: 5px;
            padding: 3px 10px;
            border-radius: 10px;
            display: inline-block;
        }

        .stat-change.up {
            background: rgba(76, 175, 80, 0.2);
            color: #4CAF50;
        }

        .stat-change.down {
            background: rgba(229, 57, 53, 0.2);
            color: #E53935;
        }

        /* ============================================
           MAIN GRID LAYOUT
        ============================================ */
        .main-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            margin-bottom: 30px;
        }

        @media (max-width: 768px) {
            .main-grid { grid-template-columns: 1fr; }
        }

        /* ============================================
           CARD COMPONENT
        ============================================ */
        .card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: var(--border-radius);
            overflow: hidden;
            transition: var(--transition);
        }

        .card:hover {
            border-color: rgba(212, 175, 55, 0.5);
            box-shadow: var(--shadow);
        }

        .card-header {
            background: rgba(44, 24, 16, 0.6);
            padding: 18px 25px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--coffee-gold);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-body {
            padding: 25px;
        }

        /* ============================================
           FORM STYLES
        ============================================ */
        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.85rem;
            color: var(--coffee-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            background: rgba(44, 24, 16, 0.6);
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 10px;
            color: var(--coffee-cream);
            font-size: 0.95rem;
            transition: var(--transition);
            outline: none;
        }

        .form-control:focus {
            border-color: var(--coffee-gold);
            background: rgba(44, 24, 16, 0.8);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.15);
        }

        .form-control option {
            background: var(--coffee-dark);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        /* ============================================
           ROASTING STAGE INDICATOR
        ============================================ */
        .roast-stages {
            display: flex;
            justify-content: space-between;
            margin: 20px 0;
            position: relative;
        }

        .roast-stages::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 10%;
            width: 80%;
            height: 2px;
            background: rgba(212, 175, 55, 0.2);
        }

        .roast-stage {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            z-index: 1;
        }

        .roast-stage-dot {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            border: 2px solid rgba(212, 175, 55, 0.3);
            background: rgba(44, 24, 16, 0.8);
            transition: var(--transition);
        }

        .roast-stage.active .roast-stage-dot {
            background: linear-gradient(135deg, var(--coffee-gold), #B8860B);
            border-color: var(--coffee-gold);
            box-shadow: 0 0 20px rgba(212, 175, 55, 0.5);
            animation: glow 1.5s ease-in-out infinite;
        }

        @keyframes glow {
            0%, 100% { box-shadow: 0 0 10px rgba(212,175,55,0.5); }
            50%       { box-shadow: 0 0 25px rgba(212,175,55,0.9); }
        }

        .roast-stage.completed .roast-stage-dot {
            background: linear-gradient(135deg, #4CAF50, #2E7D32);
            border-color: #4CAF50;
        }

        .roast-stage-label {
            font-size: 0.7rem;
            color: var(--coffee-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
        }

        .roast-stage.active .roast-stage-label {
            color: var(--coffee-gold);
            font-weight: 700;
        }

        /* ============================================
           TEMPERATURE GAUGE
        ============================================ */
        .temp-display {
            text-align: center;
            padding: 20px;
            background: rgba(44, 24, 16, 0.4);
            border-radius: 12px;
            margin: 15px 0;
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        .temp-value {
            font-size: 3.5rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--coffee-gold), #FF6B35);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
        }

        .temp-unit {
            font-size: 1.5rem;
            color: var(--coffee-light);
        }

        .temp-bar {
            height: 10px;
            background: rgba(255,255,255,0.1);
            border-radius: 5px;
            overflow: hidden;
            margin: 10px 0;
        }

        .temp-fill {
            height: 100%;
            background: linear-gradient(90deg, #4CAF50, #FF9800, #F44336);
            border-radius: 5px;
            transition: width 0.5s ease;
        }

        /* ============================================
           BLOCKCHAIN TRANSACTION LOG
        ============================================ */
        .tx-list {
            max-height: 350px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: var(--coffee-gold) transparent;
        }

        .tx-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 15px;
            border-radius: 10px;
            margin-bottom: 8px;
            background: rgba(44, 24, 16, 0.4);
            border: 1px solid rgba(212, 175, 55, 0.1);
            transition: var(--transition);
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-20px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        .tx-item:hover {
            border-color: rgba(212, 175, 55, 0.3);
            background: rgba(44, 24, 16, 0.7);
        }

        .tx-icon {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .tx-icon.success { background: rgba(76, 175, 80, 0.2); }
        .tx-icon.pending { background: rgba(255, 152, 0, 0.2); }
        .tx-icon.failed  { background: rgba(229, 57, 53, 0.2); }

        .tx-details {
            flex: 1;
        }

        .tx-name {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--coffee-cream);
        }

        .tx-hash {
            font-size: 0.75rem;
            color: var(--coffee-light);
            font-family: monospace;
        }

        .tx-status {
            font-size: 0.75rem;
            padding: 3px 10px;
            border-radius: 10px;
            font-weight: 600;
        }

        .tx-status.success { background: rgba(76,175,80,0.2);  color: #4CAF50; }
        .tx-status.pending { background: rgba(255,152,0,0.2);  color: #FF9800; }
        .tx-status.failed  { background: rgba(229,57,53,0.2);  color: #E53935; }

        /* ============================================
           ROASTING PROFILES TABLE
        ============================================ */
        .profile-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .profile-table th {
            background: rgba(44, 24, 16, 0.8);
            color: var(--coffee-gold);
            padding: 12px 15px;
            text-align: left;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.75rem;
            border-bottom: 2px solid rgba(212, 175, 55, 0.3);
        }

        .profile-table td {
            padding: 12px 15px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.1);
            color: var(--coffee-cream);
            vertical-align: middle;
        }

        .profile-table tr:hover td {
            background: rgba(212, 175, 55, 0.05);
        }

        .roast-level {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 15px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .roast-light    { background: rgba(255,235,59,0.2); color: #FFF176; }
        .roast-medium   { background: rgba(255,152,0,0.2);  color: #FFB74D; }
        .roast-dark     { background: rgba(121,85,72,0.2);  color: #A1887F; }
        .roast-espresso { background: rgba(44,24,16,0.8);   color: var(--coffee-light); border: 1px solid var(--coffee-medium); }

        /* ============================================
           NFT CERTIFICATE SECTION
        ============================================ */
        .nft-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 15px;
        }

        .nft-card {
            background: linear-gradient(135deg, rgba(44,24,16,0.8), rgba(111,78,55,0.4));
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .nft-card::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(212,175,55,0.1) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .nft-card:hover::before { opacity: 1; }

        .nft-card:hover {
            transform: translateY(-5px) scale(1.02);
            border-color: var(--coffee-gold);
            box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
        }

        .nft-image {
            font-size: 3rem;
            margin-bottom: 10px;
            display: block;
        }

        .nft-name {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--coffee-gold);
            margin-bottom: 4px;
        }

        .nft-id {
            font-size: 0.7rem;
            color: var(--coffee-light);
            font-family: monospace;
        }

        .nft-badge {
            position: absolute;
            top: 8px; right: 8px;
            background: var(--coffee-gold);
            color: var(--coffee-dark);
            font-size: 0.65rem;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 10px;
        }

        /* ============================================
           CHART CONTAINER
        ============================================ */
        .chart-container {
            position: relative;
            height: 280px;
            background: rgba(44, 24, 16, 0.3);
            border-radius: 10px;
            padding: 15px;
        }

        /* ============================================
           MODAL
        ============================================ */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 9999;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }

        .modal-overlay.show {
            display: flex;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to   { opacity: 1; }
        }

        .modal {
            background: linear-gradient(135deg, #2C1810, #4a2c1a);
            border: 1px solid rgba(212, 175, 55, 0.5);
            border-radius: 20px;
            padding: 30px;
            max-width: 500px;
            width: 90%;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .modal-title {
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--coffee-gold);
        }

        .modal-close {
            background: none;
            border: none;
            color: var(--coffee-light);
            font-size: 1.5rem;
            cursor: pointer;
            padding: 5px;
            transition: var(--transition);
        }

        .modal-close:hover { color: var(--coffee-gold); }

        /* ============================================
           NOTIFICATION TOAST
        ============================================ */
        .toast-container {
            position: fixed;
            bottom: 25px;
            right: 25px;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast {
            background: rgba(44, 24, 16, 0.95);
            border: 1px solid rgba(212, 175, 55, 0.5);
            border-radius: 12px;
            padding: 15px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 300px;
            box-shadow: var(--shadow);
            animation: toastIn 0.3s ease;
            backdrop-filter: blur(20px);
        }

        @keyframes toastIn {
            from { opacity: 0; transform: translateX(50px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        .toast.success { border-left: 4px solid var(--coffee-green); }
        .toast.error   { border-left: 4px solid var(--coffee-red); }
        .toast.info    { border-left: 4px solid var(--coffee-gold); }

        .toast-icon { font-size: 1.3rem; }
        .toast-text { flex: 1; font-size: 0.9rem; color: var(--coffee-cream); }

        /* ============================================
           LOADING SPINNER
        ============================================ */
        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(212,175,55,0.3);
            border-radius: 50%;
            border-top-color: var(--coffee-gold);
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ============================================
           SUPPLY CHAIN TRACKER
        ============================================ */
        .supply-chain {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .supply-step {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 12px 15px;
            background: rgba(44, 24, 16, 0.4);
            border-radius: 10px;
            border-left: 3px solid var(--coffee-gold);
            transition: var(--transition);
        }

        .supply-step:hover {
            background: rgba(44, 24, 16, 0.7);
            transform: translateX(5px);
        }

        .supply-step-icon {
            font-size: 1.5rem;
            width: 40px;
            text-align: center;
        }

        .supply-step-info {
            flex: 1;
        }

        .supply-step-title {
            font-weight: 700;
            color: var(--coffee-cream);
            font-size: 0.9rem;
        }

        .supply-step-detail {
            font-size: 0.75rem;
            color: var(--coffee-light);
            margin-top: 2px;
        }

        .supply-step-time {
            font-size: 0.75rem;
            color: var(--coffee-gold);
            font-family: monospace;
        }

        /* ============================================
           FOOTER
        ============================================ */
        .footer {
            background: rgba(44, 24, 16, 0.95);
            border-top: 1px solid rgba(212, 175, 55, 0.2);
            padding: 25px 30px;
            margin-top: 40px;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1400px;
            margin: 0 auto;
            flex-wrap: wrap;
            gap: 15px;
        }

        .footer-links {
            display: flex;
            gap: 20px;
        }

        .footer-link {
            color: var(--coffee-light);
            text-decoration: none;
            font-size: 0.85rem;
            transition: var(--transition);
        }

        .footer-link:hover { color: var(--coffee-gold); }

        .footer-copy {
            font-size: 0.8rem;
            color: var(--coffee-light);
        }

        /* ============================================
           RESPONSIVE
        ============================================ */
        @media (max-width: 768px) {
            .navbar { flex-direction: column; gap: 15px; }
            .wallet-panel { flex-direction: column; }
            .wallet-stats { gap: 15px; }
            .form-row { grid-template-columns: 1fr; }
            .roast-stages { flex-wrap: wrap; gap: 10px; }
            .roast-stages::before { display: none; }
        }

        /* ============================================
           SCROLLBAR
        ============================================ */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: rgba(44,24,16,0.3); }
        ::-webkit-scrollbar-thumb {
            background: var(--coffee-gold);
            border-radius: 3px;
        }

        .full-width { grid-column: 1 / -1; }
    </style>
